# Copy to .env and fill in values. Repo-root .env is loaded by the backend (see EnvConnectionLoader) and by Python scripts.

# --- Azure SQL (required for backend) ---
DB_SERVER=your-server.database.windows.net
DB_NAME=YourDb
DB_USER=youruser
DB_PASSWORD=yourpassword

# --- Seed users (required) — each password must be at least 14 characters ---
Seed__AdminPassword=YourAdminPassword14chars+
Seed__DonorPassword=YourDonorPassword14chars+
Seed__MfaAdminPassword=YourMfaPassword14chars+

# --- JWT (required) ---
Jwt__Issuer=IntexBackend
Jwt__Audience=IntexFrontend
Jwt__Secret=ChangeThisToALongRandomSecretKey1234567890!

# --- Public URL of the React app (password reset links in emails) ---
# Production: https://your-frontend.azurestaticapps.net
PasswordReset__FrontendBaseUrl=http://localhost:5173

# --- SMTP: send real password-reset emails (optional in dev if you use log fallback) ---
# Examples:
#   Mailtrap (testing): host smtp.mailtrap.io, port 587, user/password from inbox SMTP credentials
#   Gmail: smtp.gmail.com, 587, your address, Google "App password"
#   SendGrid: smtp.sendgrid.net, 587, user "apikey", password = your API key, From = verified sender
# Leave Smtp__Host empty to skip sending (Development logs the reset link instead).
Smtp__Host=
Smtp__Port=587
Smtp__User=
Smtp__Password=
Smtp__From=
